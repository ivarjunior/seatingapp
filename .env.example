# Wachtwoord voor lokaal opslaan via /admin (alleen bij SEATING_DATA_SOURCE=local)
ADMIN_PASSWORD=verander-mij

# Publieke URL voor QR-codes (bijv. https://seating.jouwdomein.nl of http://192.168.1.10:3010)
NEXT_PUBLIC_APP_URL=

# --- Koppeling met Ivarium Labs (aanbevolen) ---
# Zelfde token als PUBLIC_WEDDING_SEATING_TOKEN in frontend/.env.local
IVARIUM_API_URL=http://127.0.0.1:3001
IVARIUM_SEATING_EVENT_ID=
IVARIUM_SEATING_TOKEN=

# Optioneel: forceer bron (ivarium | local). Standaard: ivarium als bovenstaande vars gezet zijn.
# SEATING_DATA_SOURCE=ivarium

# Link in /admin naar seating in Ivarium Labs
IVARIUM_ADMIN_SEATING_URL=http://127.0.0.1:3001/admin/events/weddings
